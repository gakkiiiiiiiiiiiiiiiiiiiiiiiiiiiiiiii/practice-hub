{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path": "pages/bank/index",
			"style": {
				"navigationBarTitleText": "题库",
				"enablePullDownRefresh": true
			}
		},
		{
			"path": "pages/user/index",
			"style": {
				"navigationBarTitleText": "我的",
				"enablePullDownRefresh": true
			}
		},
		{
			"path": "pages/answer/index",
			"style": {
				"navigationBarTitleText": "答题",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/login/index",
			"style": {
				"navigationBarTitleText": "登录"
			}
		}
	],
	"subPackages": [
		{
			"root": "pages/sub-pages",
			"pages": [
				{
					"path": "activation/index",
					"style": {
						"navigationBarTitleText": "激活码兑换"
					}
				},
				{
					"path": "order/index",
					"style": {
						"navigationBarTitleText": "订单列表"
					}
				},
				{
					"path": "wrong/index",
					"style": {
						"navigationBarTitleText": "错题集"
					}
				},
				{
					"path": "rank/index",
					"style": {
						"navigationBarTitleText": "排行榜"
					}
				},
				{
					"path": "trajectory/index",
					"style": {
						"navigationBarTitleText": "学习轨迹"
					}
				}
			]
		}
	],
	"tabBar": {
		"color": "#7A7E83",
		"selectedColor": "#3cc51f",
		"borderStyle": "black",
		"backgroundColor": "#ffffff",
		"list": [
			{
				"pagePath": "pages/index/index",
				"iconPath": "static/tabbar/home.png",
				"selectedIconPath": "static/tabbar/home-active.png",
				"text": "首页"
			},
			{
				"pagePath": "pages/bank/index",
				"iconPath": "static/tabbar/book.png",
				"selectedIconPath": "static/tabbar/book-active.png",
				"text": "题库"
			},
			{
				"pagePath": "pages/user/index",
				"iconPath": "static/tabbar/user.png",
				"selectedIconPath": "static/tabbar/user-active.png",
				"text": "我的"
			}
		]
	},
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "考研刷题",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	}
}
